rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /setoran/{docId} {
      // Semua orang bisa LIHAT data (tanpa login)
      allow read: if true;
      // Hanya admin yang sudah login bisa tambah / edit / hapus
      allow create, update, delete: if request.auth != null;
    }
  }
}
